{$CLEO .cs}
int key = read_int_from_ini_file "cleo\gotozero.ini" "Controls" "Activate"
int debug = read_int_from_ini_file "cleo\gotozero.ini" "Advanced" "Debug"
int mem0chk = 0x20010002
int mem1chk = 0x730000AB

while true
    wait 0
    if
        is_key_pressed key
    then
        int mainPtr = get_script_struct_named 'MAIN'
        if
            mainPtr > 0
        then
            int currentInstructionPtrPtr = mainPtr + 0x14
            int baseInstructionPtr = mainPtr + -0x046DF0
            int mem0 = read_memory baseInstructionPtr 4 false
            int mem1 = read_memory_with_offset baseInstructionPtr 4 4
            if
                debug == true
            then
                print_help_formatted "%#X" baseInstructionPtr  
                wait 3550
            end
            if and // check scm for match
                mem0 == mem0chk
                mem1 == mem1chk
            then
                write_memory currentInstructionPtrPtr 4 baseInstructionPtr false
                terminate_this_script
            else
                handleError("MAGIC_NOT_EQUAL")
            end
        else
            handleError("SCRIPT_NOT_FOUND")
            terminate_this_script
        end
    end
end

terminate_this_script

function handleError(errMsg: longstring)
    wait 200
    print_help_string "gotozero_ERROR"
    wait 2550
    print_help_string errMsg
    terminate_this_script
end
